# Databricks App Configuration
# Copy to `.env` or `.env.local` for local values. Use `.env.local` for PAT/host/paths — it is gitignored.
# Do not commit `.env.local` or any file containing real tokens.

# Databricks Authentication Type
DATABRICKS_AUTH_TYPE=pat

# Databricks Configuration (PAT mode)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com/?o=YOUR_ORG_ID
DATABRICKS_TOKEN=dapi_your_token_here

# Databricks App Configuration
DATABRICKS_APP_NAME=va-claims-dashboard
DBA_SOURCE_CODE_PATH=/Workspace/Users/your.email@example.com/VAClaimsDashboard

# Unity Catalog (fedhealth demo workspace — override if your workspace differs)
DATABRICKS_UC_CATALOG=fedhealth_demo_ws_catalog
DATABRICKS_UC_SCHEMA=vba_claims_agent

# Optional: SQL warehouse ID for ClaimsService SQL (timeseries, doc chunks). Use when auto-selection fails in Apps.
# DATABRICKS_SQL_WAREHOUSE_ID=

# Model serving: full URL to /invocations for evaluate-agent proxy (optional)
# DATABRICKS_SERVING_ENDPOINT_URL=https://your-workspace.cloud.databricks.com/serving-endpoints/your-endpoint/invocations

# Optional: dedicated OpenAI-style adjudication suggest endpoint (overrides SERVING_ENDPOINT for /adjudication/suggest)
# DATABRICKS_ADJUDICATION_SUGGEST_URL=https://your-workspace.cloud.databricks.com/serving-endpoints/adjudication-suggest/invocations

# Frontend (Vite): Genie space URL — same hostname as DATABRICKS_HOST; used for "open in new tab" in the dashboard (set at build time)
# VITE_GENIE_SPACE_URL=https://your-workspace.cloud.databricks.com/genie/spaces/...

# Genie Conversation API (floating "Ask Genie" chat): space ID or URL path the backend proxies with DATABRICKS_TOKEN
# DATABRICKS_GENIE_SPACE_ID=
# Or set a URL containing /genie/spaces/{uuid} (parsed on the server; can match VITE_GENIE_SPACE_URL)
# DATABRICKS_GENIE_SPACE_URL=

# Optional: User email
DATABRICKS_USER=your.email@example.com
