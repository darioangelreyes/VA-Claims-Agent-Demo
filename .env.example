# Databricks App Configuration
# Copy this file to .env and fill in your credentials

# Databricks Authentication Type
DATABRICKS_AUTH_TYPE=pat

# Databricks Configuration (PAT mode)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com/?o=YOUR_ORG_ID
DATABRICKS_TOKEN=dapi_your_token_here

# Databricks App Configuration
DATABRICKS_APP_NAME=va-claims-dashboard
DBA_SOURCE_CODE_PATH=/Workspace/Users/your.email@example.com/VAClaimsDashboard

# Unity Catalog (VA Claims AI defaults — override if your workspace differs)
DATABRICKS_UC_CATALOG=va_claims_ai
DATABRICKS_UC_SCHEMA=vba_claims_agent

# Model serving: full URL to /invocations for evaluate-agent proxy (optional)
# DATABRICKS_SERVING_ENDPOINT_URL=https://your-workspace.cloud.databricks.com/serving-endpoints/your-endpoint/invocations

# Optional: User email
DATABRICKS_USER=your.email@example.com
